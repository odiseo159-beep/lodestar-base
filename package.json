{
  "name": "lodestar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local --import tsx ./lib/db/migrate.ts",
    "db:push": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.1",
    "@auth/drizzle-adapter": "^1.11.2",
    "@octokit/rest": "^22.0.1",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "siwe": "^3.0.0",
    "viem": "^2.51.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
